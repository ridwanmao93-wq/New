# --- Supabase ---
# Project URL and keys from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only mirrors (used by API routes and CLI scripts)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key — server only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# --- Oura ---
# Personal Access Token from https://cloud.ouraring.com/personal-access-tokens
OURA_ACCESS_TOKEN=

# --- Cron / CLI (single-user automation) ---
# Used by Vercel Cron (Authorization: Bearer <CRON_SECRET>) and CLI scripts
# so the daily Oura sync can run without a browser session.
CRON_SECRET=
# Your Supabase auth user id (Authentication → Users). Lets cron/CLI jobs
# know which user to sync. Find it after signing in once.
DASHBOARD_USER_ID=
